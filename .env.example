# APP_URL: La URL donde esta aplicación está alojada.
# Usado para enlaces, callbacks y endpoints de API.
APP_URL="http://localhost:3000"

# Modo de operación del sistema
# Valores: 'localStorage' o 'api'
# localStorage: Almacenamiento local en el navegador (sin backend)
# api: Backend PostgreSQL con REST API
VITE_STORAGE_MODE=localStorage

# URL del backend API (solo necesario si VITE_STORAGE_MODE=api)
VITE_API_URL=http://localhost:3001/api
